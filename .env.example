# Αντιγράψτε σε Vercel → Project → Settings → Environment Variables
# Τοπικά: χρησιμοποιήστε `vercel dev` (όχι `npm run dev`) για να δουλεύουν τα /api/*

GOOGLE_PLACES_API_KEY=

# Προαιρετικά — αν η αυτόματη αναζήτηση δεν βρίσκει το studio:
# GOOGLE_PLACE_RESOURCE_NAME=places/ChIJxxxxxxxxxxxxxxxx
# GOOGLE_PLACES_SEARCH_TEXT=Moove Fitness Boutique Studio Κοραή Βόλος

# --- Move & Pose: Supabase + Stripe + Resend ---
# Setup: docs/posing-booking-setup.md

# Frontend (Vite)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Backend (Vercel API — μην εκθέτεις στο client)
# SUPABASE_URL είναι ΥΠΟΧΡΕΩΤΙΚΟ για /api/posing/* — δεν αρκεί μόνο το VITE_SUPABASE_URL
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
POSE_ADMIN_EMAILS=info@moovefitness.gr

# Email — Resend (προτιμώμενο με ImprovMX forwarding)
# Οδηγός: docs/email-improvmx-resend.md
RESEND_API_KEY=re_...
CONTACT_FROM_EMAIL=Moove <noreply@moovefitness.gr>
CONTACT_NOTIFY_EMAIL=info@moovefitness.gr
POSE_FROM_EMAIL=Move & Pose <info@moovefitness.gr>
POSE_NOTIFY_EMAIL=info@moovefitness.gr

# Email εναλλακτικά — Google Workspace ή ImprovMX Premium SMTP
# Αν ορίσεις SMTP_USER + SMTP_PASS, το API προτιμά SMTP έναντι Resend
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=info@moovefitness.gr
# SMTP_PASS=

# Stripe Checkout (προτιμώμενο — webhook ενεργοποιεί πακέτο/κράτηση)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SINGLE=price_...
STRIPE_PRICE_SAPPHIRE=price_...
STRIPE_PRICE_RUBY=price_...
STRIPE_PRICE_DIAMOND=price_...
STRIPE_PRICE_RUBY_JULY8=price_...
STRIPE_PRICE_DIAMOND_JULY8=price_...
POSE_SUCCESS_URL=https://moovefitness.gr/posing?payment=success
POSE_CANCEL_URL=https://moovefitness.gr/posing#booking

# PayPal / Revolut (pre-filled amount links in booking emails)
POSE_PAYPAL_URL=https://www.paypal.me/magdalinisamara
POSE_REVOLUT_URL=https://revolut.me/magdaqsn9

# Fallback static Payment Links (χωρίς auto-confirm webhook)
STRIPE_LINK_SINGLE=https://buy.stripe.com/...
STRIPE_LINK_SAPPHIRE=https://buy.stripe.com/...
STRIPE_LINK_RUBY=https://buy.stripe.com/...
STRIPE_LINK_DIAMOND=https://buy.stripe.com/...
STRIPE_LINK_RUBY_JULY8=https://buy.stripe.com/...
STRIPE_LINK_DIAMOND_JULY8=https://buy.stripe.com/...
